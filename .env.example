# Optional: force-reset admin password on startup.
# The app sets must-change-password=true when this is used.
# Remove this value after successful reset.
RESET_ADMIN_PASSWORD=

# Optional paths (defaults shown)
DATA_DIR=/app/data
DB_PATH=/app/data/liveu_monitor.db
CERT_PATH=/app/data/certs/server.crt
KEY_PATH=/app/data/certs/server.key

# Session settings
SESSION_IDLE_TIMEOUT_SECONDS=600
METRICS_INTERVAL_SECONDS=1

# Security hardening toggles
# Keep false unless this app sits behind a trusted reverse proxy that sets X-Forwarded-For.
TRUST_X_FORWARDED_FOR=false
# Keep false in production to avoid exposing API schema/docs.
ENABLE_API_DOCS=false
