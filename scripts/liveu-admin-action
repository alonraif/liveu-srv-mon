#!/usr/bin/env bash
set -euo pipefail

action="${1:-}"

case "$action" in
  restart-liveu)
    exec sudo -n /usr/bin/env SYSTEMCTL_FORCE_BUS=1 /usr/bin/systemctl restart liveu
    ;;
  reboot)
    # Use nsenter to reboot the host from the container
    # PID 1 is always init/systemd on the host
    exec sudo -n nsenter -t 1 -p -m -n -- /sbin/reboot
    ;;
  *)
    echo "Unsupported action" >&2
    exit 2
    ;;
esac
